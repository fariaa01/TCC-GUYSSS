<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= empresaNome %> — Checkout</title>
  <link rel="stylesheet" href="/cardapio/checkout.css" />
</head>
<body>
  <div class="wrap">
    <header style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <h1 style="margin:0"><%= empresaNome %> — Checkout</h1>
      <a href="/cardapio" class="btn-ghost">↩ Voltar ao cardápio</a>
    </header>

    <div class="grid">
      <!-- COL ESQUERDA: DADOS DO CLIENTE / ENTREGA / OBS -->
      <section class="panel">
        <h3>Seus dados</h3>
        <p class="sub">Preencha seu nome e telefone/WhatsApp. Se for entrega, informe o endereço.</p>

        <!-- Tipo de atendimento -->
        <div class="sub" style="margin-bottom:10px">
          <strong>Como você prefere receber?</strong>
        </div>
        <div class="pay-tabs" id="tabs-atendimento" style="margin-bottom:16px">
          <button type="button" class="pay-tab active" data-mode="dine">Comer no local</button>
          <button type="button" class="pay-tab" data-mode="pickup">Retirar</button>
          <button type="button" class="pay-tab" data-mode="delivery">Entrega</button>
        </div>

        <!-- Formulário -->
        <form id="formCheckout" class="form-grid" novalidate>
          <div class="field full">
            <span>Nome</span>
            <input id="ch_nome" name="nome" type="text" required placeholder="Seu nome"/>
          </div>

          <div class="field full">
            <span>Telefone / WhatsApp</span>
            <input id="ch_tel" name="telefone" type="tel" required placeholder="(DDD) 9 9999-9999"/>
          </div>

          <!-- Endereço: mostrado APENAS se modo = delivery -->
          <div id="enderecoBox" class="full" style="display:none">
            <div class="field full">
              <span>Endereço</span>
              <input id="ch_end" name="endereco" type="text" placeholder="Rua, número, complemento"/>
            </div>
            <div class="field">
              <span>Bairro</span>
              <input id="ch_bairro" name="bairro" type="text"/>
            </div>
            <div class="field">
              <span>Cidade</span>
              <input id="ch_cidade" name="cidade" type="text"/>
            </div>
            <div class="field">
              <span>UF</span>
              <input id="ch_uf" name="uf" type="text" maxlength="2"/>
            </div>
            <div class="field">
              <span>CEP</span>
              <input id="ch_cep" name="cep" type="text" placeholder="00000-000"/>
            </div>
          </div>

          <div class="field full">
            <span>Observações</span>
            <input id="ch_obs" name="observacoes" type="text" placeholder="Sem cebola, ponto da carne, etc."/>
          </div>

          <div class="field full">
            <span>Forma de pagamento</span>
            <div class="pay-tabs" id="tabs-pagamento">
              <button type="button" class="pay-tab active" data-pay="cash">Dinheiro</button>
              <button type="button" class="pay-tab" data-pay="debit">Débito</button>
              <button type="button" class="pay-tab" data-pay="credit">Crédito</button>
              <button type="button" class="pay-tab" data-pay="ewallet">Pix</button>
            </div>
          </div>

          <div class="field full">
            <button id="btn-finalizar" class="btn-primary" type="submit">Finalizar pedido</button>
            <p id="fb" class="muted" aria-live="polite" style="margin-top:8px"></p>
          </div>
        </form>
      </section>

      <!-- COL DIREITA: RESUMO DO PEDIDO -->
      <aside class="panel">
        <h3>Resumo do pedido</h3>
        <p class="sub">Confira os itens antes de finalizar.</p>

        <div id="summaryList" class="summary"></div>

        <hr class="line"/>

        <div class="rows">
          <div class="row"><span>Itens</span><strong id="sumSubtotal">R$ 0,00</strong></div>
          <div class="row"><span>Taxas</span><strong id="sumTax">R$ 0,00</strong></div>
          <div class="row"><span>Entrega</span><strong id="sumShipping">R$ 0,00</strong></div>
          <div class="row total"><span>Total</span><strong id="sumTotal">R$ 0,00</strong></div>
        </div>

        <hr class="line"/>
      </aside>
    </div>
  </div>

  <script nonce="<%= cspNonce %>" src="/cardapio/checkout.js"></script>
</body>
</html>
